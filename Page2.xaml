<Page x:Class="Практическая_работа_4_Колчин_Михайлова.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page2">

    <Grid Margin="20" Background="White" RenderTransformOrigin="0.974,0.041">

        <Grid.RowDefinitions>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="81*"/>
            <RowDefinition Height="28*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <!-- X -->
        <TextBlock Text="x"
                   Grid.Row="2"
                   VerticalAlignment="Top" Margin="17,4,10,0" Height="21"/>

        <TextBox x:Name="txtX"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="10,4,70,71"
                 ToolTip="Введите x"/>

        <!-- P -->
        <TextBlock Text="p"
                   Grid.Row="2"
                   VerticalAlignment="Center" Margin="17,0,10,0" Height="20"/>

        <TextBox x:Name="txtP"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="10,44,70,33"
                 ToolTip="Введите p"/>

        <!-- Выбор функции -->

        <RadioButton x:Name="rbSh"
                     Content="sh(x)"
                     Grid.Row="2"
                     Grid.Column="1" Margin="10,97,84,46" Grid.RowSpan="2"/>

        <RadioButton x:Name="rbX2"
                     Content="x²"
                     Grid.Row="3"
                     Grid.Column="1" Margin="10,16,70,10"/>

        <RadioButton x:Name="rbExp"
                     Content="e^x"
                     Grid.Row="3"
                     Grid.Column="1" Margin="10,37,91,10"/>

        <!-- Кнопка вычислить -->

        <Button Content="Вычислить"
                Grid.Row="2"
                Grid.Column="2"
                Click="BtnCalculate_Click"
                Margin="10,10,49,55"/>

        <!-- Кнопка очистить -->

        <Button Content="Очистить"
                Grid.Row="2"
                Grid.Column="2"
                Click="BtnClear_Click"
                Margin="10,58,49,16"/>

        <!-- Ответ -->

        <TextBlock Text="Ответ:"
                   Grid.Row="4"
                   VerticalAlignment="Center" Height="16"/>

        <TextBox x:Name="txtResult"
                 Grid.Row="4"
                 Grid.Column="1"
                 Margin="5,5,5,5"
                 IsReadOnly="True"/>
        <Image Grid.ColumnSpan="2" Margin="26,9,46,1" Grid.RowSpan="2" Source="/Снимок экрана 2026-03-05 224952.png" Stretch="Fill"/>

    </Grid>
</Page>